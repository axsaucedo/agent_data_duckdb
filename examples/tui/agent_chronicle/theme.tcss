/* Agent Chronicle — Dynamic Theme CSS
 *
 * Colors come from Textual's Theme system via $variables.
 * Themes are registered in themes.py and switched with 't' key.
 */

/* ── Base ─────────────────────────────────────────── */

Screen {
    background: $background;
}

Header {
    background: $panel;
    color: $foreground;
}

Footer {
    background: $panel;
    color: $foreground 60%;
}

/* ── Tabs ─────────────────────────────────────────── */

TabbedContent {
    background: $background;
    height: 1fr;
}

ContentSwitcher {
    background: $background;
    height: 1fr;
}

TabPane {
    background: $background;
    padding: 1 2;
    height: 1fr;
}

Tabs {
    background: $panel;
    dock: top;
}

Tab {
    background: $panel;
    color: $foreground 40%;
    padding: 0 2;
}

Tab.-active {
    color: $primary;
    text-style: bold;
    background: $surface;
}

Tab:hover {
    color: $foreground;
}

/* ── Typography ───────────────────────────────────── */

Static {
    color: $foreground;
}

/* ── DataTable ────────────────────────────────────── */

DataTable {
    background: $background;
    color: $foreground;
    height: 1fr;
}

DataTable > .datatable--header {
    background: $surface;
    color: $primary;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: $surface;
    color: $foreground;
    text-style: bold;
}

DataTable > .datatable--even-row {
    background: $background;
}

DataTable > .datatable--odd-row {
    background: $background 80%;
}

DataTable:focus > .datatable--cursor {
    background: $accent;
    color: $foreground;
}

/* ── Input / TextArea ─────────────────────────────── */

Input {
    background: $surface;
    color: $foreground;
    border: tall $surface;
}

Input:focus {
    border: tall $primary;
}

TextArea {
    background: $surface;
    color: $foreground;
}

/* ── Buttons ──────────────────────────────────────── */

Button {
    background: $surface;
    color: $foreground;
    border: tall $surface;
}

Button:hover {
    background: $primary 20%;
    color: $foreground;
}

Button.-primary {
    background: $primary;
    color: $background;
    border: tall $primary;
    text-style: bold;
}

Button.-primary:hover {
    background: $primary 80%;
}

Select {
    background: $surface;
    color: $foreground;
}

/* ── Help overlay ─────────────────────────────────── */

HelpScreen {
    background: $background 88%;
    align: center middle;
}

#help-dialog {
    background: $surface;
    border: heavy $primary;
    padding: 2 4;
    width: 72;
    height: auto;
    max-height: 36;
}

/* ── Loading indicator ────────────────────────────── */

.loading-indicator {
    color: $foreground 40%;
    text-style: italic;
}
