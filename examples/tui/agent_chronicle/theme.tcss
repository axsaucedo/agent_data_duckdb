/* Agent Chronicle — Catppuccin Mocha-inspired Theme */

/* ── Base ─────────────────────────────────────────── */

Screen {
    background: #1e1e2e;
}

Header {
    background: #181825;
    color: #cdd6f4;
}

Footer {
    background: #181825;
    color: #a6adc8;
}

/* ── Tabs ─────────────────────────────────────────── */

TabbedContent {
    background: #1e1e2e;
    height: 1fr;
}

ContentSwitcher {
    background: #1e1e2e;
    height: 1fr;
}

TabPane {
    background: #1e1e2e;
    padding: 1 2;
    height: 1fr;
}

Tabs {
    background: #181825;
    dock: top;
}

Tab {
    background: #181825;
    color: #6c7086;
    padding: 0 2;
}

Tab.-active {
    color: #a6e3a1;
    text-style: bold;
    background: #313244;
}

Tab:hover {
    color: #cdd6f4;
}

/* ── Typography ───────────────────────────────────── */

Static {
    color: #cdd6f4;
}

/* ── DataTable ────────────────────────────────────── */

DataTable {
    background: #1e1e2e;
    color: #cdd6f4;
    height: 1fr;
}

DataTable > .datatable--header {
    background: #313244;
    color: #a6e3a1;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #45475a;
    color: #cdd6f4;
    text-style: bold;
}

DataTable > .datatable--even-row {
    background: #1e1e2e;
}

DataTable > .datatable--odd-row {
    background: #232336;
}

DataTable:focus > .datatable--cursor {
    background: #585b70;
    color: #cdd6f4;
}

/* ── Input / TextArea ─────────────────────────────── */

Input {
    background: #313244;
    color: #cdd6f4;
    border: tall #45475a;
}

Input:focus {
    border: tall #a6e3a1;
}

TextArea {
    background: #313244;
    color: #cdd6f4;
}

/* ── Buttons ──────────────────────────────────────── */

Button {
    background: #45475a;
    color: #cdd6f4;
    border: tall #585b70;
}

Button:hover {
    background: #585b70;
    color: #cdd6f4;
}

Button.-primary {
    background: #a6e3a1;
    color: #1e1e2e;
    border: tall #a6e3a1;
    text-style: bold;
}

Button.-primary:hover {
    background: #94e2d5;
}

Select {
    background: #313244;
    color: #cdd6f4;
}

/* ── Help overlay ─────────────────────────────────── */

HelpScreen {
    background: rgba(17, 17, 27, 0.88);
    align: center middle;
}

#help-dialog {
    background: #313244;
    border: heavy #a6e3a1;
    padding: 2 4;
    width: 72;
    height: auto;
    max-height: 36;
}

/* ── Loading indicator ────────────────────────────── */

.loading-indicator {
    color: #6c7086;
    text-style: italic;
}
